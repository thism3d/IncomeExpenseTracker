PORT=5051
NODE_ENV=development

# Database — PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/sisirbindu
DB_SSL=false

# Auth
JWT_SECRET=change-me-to-a-long-random-hex-string
JWT_EXPIRY=30d
BCRYPT_ROUNDS=12

# Admin bootstrap account (seeded on first boot)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_NAME=SisirBindu Admin

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=SISIRBINDU TRACKERAPP

# Phone SMS (BulkSMSBD)
BULKSMSBD_API_KEY=
BULKSMSBD_SENDER_ID=
BULKSMSBD_URL=http://bulksmsbd.net/api/smsapi

# Super-admin alert recipients
ADMIN_ALERT_EMAIL=
ADMIN_ALERT_PHONE=

# Stores a plaintext copy of every password so the admin panel can show it. Testing only.
SHOW_USER_PASSWORDS=false

# File storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=50

# Frontend
FRONTEND_URL=http://localhost:5050
